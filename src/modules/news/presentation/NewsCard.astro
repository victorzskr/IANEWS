---
import type { NewsItem, TimelineAccent } from "../domain/news-item";

interface Props {
  item: NewsItem;
  accent: TimelineAccent;
  side: "left" | "right";
}

const { item, accent, side } = Astro.props;

const accentClass = {
  lime: "text-lime-300",
  cyan: "text-cyan-300",
  neutral: "text-neutral-300"
}[accent];

const confidenceClass = {
  High: "border-lime-300/40 bg-lime-300/10 text-lime-200",
  Medium: "border-cyan-300/40 bg-cyan-300/10 text-cyan-200",
  Low: "border-neutral-400/40 bg-neutral-400/10 text-neutral-200"
}[item.confidence];
---

<article
  class:list={[
    "news-card group relative rounded-lg border border-white/12 bg-white/[0.045] p-5 shadow-2xl shadow-black/30 backdrop-blur-md transition duration-200 hover:-translate-y-0.5 hover:border-white/25 hover:bg-white/[0.065] sm:p-6",
    side === "left" ? "lg:text-left" : "lg:text-left"
  ]}
  data-news-card
  data-title={item.title}
  data-summary={item.summary}
  data-source={item.source}
  data-source-account={item.sourceAccount}
  data-why-it-matters={item.whyItMatters}
  data-tags={item.tags.join(" ")}
>
  <h2 class="text-balance text-lg font-extrabold leading-snug text-white sm:text-xl">
    {item.title}
  </h2>
  <p class="mt-3 max-w-prose font-mono text-sm leading-7 text-neutral-300">
    {item.summary}
  </p>
  <p class="mt-4 border-l border-white/15 pl-4 text-sm leading-6 text-neutral-200">
    <span class="font-semibold text-white">Por que importa:</span> {item.whyItMatters}
  </p>
  <div class="mt-5 border-t border-white/10 pt-4">
    <div class="flex flex-wrap items-center justify-between gap-3 font-mono text-sm">
      <div class="flex flex-wrap items-center gap-2 text-neutral-300">
        <span>Fuente: {item.source}</span>
        <span aria-hidden="true">/</span>
        <span>{item.sourceAccount}</span>
        <span class:list={["rounded-full border px-2 py-1 text-xs", confidenceClass]}>
          {item.confidence}
        </span>
      </div>
      <a
        href={item.url}
        target="_blank"
        rel="noreferrer"
        class:list={[
          "inline-flex items-center gap-2 font-semibold transition hover:text-white focus:outline-none focus:ring-2 focus:ring-cyan-300/60",
          accentClass
        ]}
      >
        Leer fuente
        <svg class="size-4" aria-hidden="true" viewBox="0 0 24 24" fill="none">
          <path
            d="M14 4h6v6m0-6-9 9m-3-7H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2v-2"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          ></path>
        </svg>
      </a>
    </div>
  </div>
</article>
