---
interface Props {
  updateStatus: string;
}

const { updateStatus } = Astro.props;
---

<header class="fixed inset-x-0 top-0 z-20 border-b border-white/[0.04] bg-[#05060a]/80 backdrop-blur-xl">
  <div class="grid min-h-20 grid-cols-1 items-center gap-4 px-5 py-4 sm:px-8 lg:grid-cols-[1fr_minmax(320px,660px)_1fr] lg:gap-8">
    <a
      href="/"
      class="justify-self-start text-2xl font-black tracking-normal text-white sm:text-3xl"
      aria-label="IANEWS home"
    >
      IANEWS
    </a>

    <label class="relative w-full justify-self-center" for="news-search">
      <span class="sr-only">Buscar noticias</span>
      <svg
        class="pointer-events-none absolute left-4 top-1/2 size-5 -translate-y-1/2 text-neutral-500"
        aria-hidden="true"
        viewBox="0 0 24 24"
        fill="none"
      >
        <path
          d="m21 21-4.35-4.35m1.35-5.15a6.5 6.5 0 1 1-13 0 6.5 6.5 0 0 1 13 0Z"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        ></path>
      </svg>
      <input
        id="news-search"
        type="search"
        autocomplete="off"
        placeholder="Buscar noticias..."
        class="h-12 w-full rounded-lg border border-white/15 bg-black/20 pl-12 pr-4 text-base text-white outline-none transition placeholder:text-neutral-500 focus:border-cyan-300/80 focus:ring-2 focus:ring-cyan-300/20"
      />
    </label>

    <div class="flex items-center justify-start gap-4 justify-self-stretch text-sm text-neutral-300 lg:justify-self-end">
      <div class="flex items-center gap-2">
        <span class="size-2.5 rounded-full bg-lime-300 shadow-[0_0_18px_rgba(190,242,100,0.8)]"></span>
        <span>{updateStatus}</span>
      </div>
    </div>
  </div>
</header>
